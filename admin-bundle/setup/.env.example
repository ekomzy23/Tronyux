# ============================================================
# RUNYX backend setup — .env
# Copy this to ".env" in the /setup folder and fill in real values.
# The API key is SECRET — it lives here only, never in the frontend.
# ============================================================

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id

# Create at: Appwrite Console → your project → Overview → Integrations → API Keys
# Give it scopes: databases.read, databases.write, collections.read, collections.write,
#                 attributes.read, attributes.write, indexes.read, indexes.write,
#                 documents.read, documents.write, buckets.read, buckets.write
APPWRITE_API_KEY=your_secret_api_key
